# Copy this file to .env.local for local development
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MedLine Website <your-email@gmail.com>"
CONTACT_RECEIVER_EMAIL=ganjishivasai4@gmail.com
BOOKING_RECEIVER_EMAIL=ganjishivasai4@gmail.com
RECEIVER_EMAIL=ganjishivasai4@gmail.com

ADMIN_LOGIN_EMAIL=admin@medlinelabs.com
ADMIN_LOGIN_PASSWORD=Admin@123
ADMIN_SESSION_SECRET=replace-with-a-strong-random-string

# Optional: persistent announcement storage path (works on most traditional hosts)
# Example: ./data/announcement.json or /var/app/data/announcement.json
ANNOUNCEMENT_STORAGE_FILE=./data/announcement.json

# Optional: KV storage (recommended for serverless/ephemeral environments)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
ANNOUNCEMENT_KV_KEY=medline:announcement
