SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=medlinelabs2014@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM="MedLine Website <medlinelabs2014@gmail.com>"
CONTACT_RECEIVER_EMAIL=medlinelabs2014@gmail.com
BOOKING_RECEIVER_EMAIL=medlinelabs2014@gmail.com
RECEIVER_EMAIL=medlinelabs2014@gmail.com
NEXT_PUBLIC_SITE_URL=https://medlinelabs.com

ADMIN_LOGIN_EMAIL=medlinelabs2014@gmail.com
ADMIN_LOGIN_PASSWORD=Admin@123
ADMIN_SESSION_SECRET=replace-with-a-strong-random-string

# Optional: persistent announcement storage path (works on most traditional hosts)
# Example: ./data/announcement.json or /var/app/data/announcement.json
ANNOUNCEMENT_STORAGE_FILE=./data/announcement.json

# Optional: KV storage (recommended for serverless/ephemeral environments)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# or Upstash-native names (equivalent):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
ANNOUNCEMENT_KV_KEY=medline:announcement
